{
  "openapi": "3.0.0",
  "info": {
    "title": "T-SAFV API",
    "version": "0.9.0",
    "description": "Spec mínima para integración con la APP"
  },
  "servers": [{ "url": "http://localhost:3000" }],
  "paths": {
    "/api/auth/register": {
      "post": { "summary": "Registro de usuario" }
    },
    "/api/auth/login": { "post": { "summary": "Login (JWT)" } },
    "/api/asociaciones": { "post": { "summary": "Crear asociación (auth)" } },
    "/api/invitaciones": { "post": { "summary": "Crear invitación (asoc admin)" } },
    "/api/invitaciones/respond": { "post": { "summary": "Aceptar invitación" } },
    "/api/unidades": { "post": { "summary": "Crear unidad" } },
    "/api/asociaciones/{asociacion_id}/membresias/{membresia_id}/state": { "post": { "summary": "Cambiar estado de membresía" } }
  }
}
